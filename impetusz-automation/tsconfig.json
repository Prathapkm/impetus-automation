{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@steps/*": ["src/steps/*"],
      "@support/*": ["src/support/*"]
    }
  },
  "include": ["src/**/*.ts", "features/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
